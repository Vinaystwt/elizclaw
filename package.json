{
  "name": "@elizclaw/agent",
  "version": "1.0.0",
  "description": "Personal automation agent — set it once, runs forever.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --external express --external express-rate-limit --out-dir dist",
    "start": "tsc && node --loader ts-node/esm src/index.ts",
    "dev": "tsc && node --loader ts-node/esm src/index.ts",
    "seed": "node scripts/seed-demo-data.mjs",
    "test": "bun test",
    "eliza": "elizaos agent start",
    "clean": "rm -rf dist data"
  },
  "dependencies": {
    "@elizaos/client-direct": "0.1.9",
    "@elizaos/core": "0.1.9",
    "@elizaos/plugin-bootstrap": "0.1.9",
    "@tavily/core": "0.0.2",
    "express-rate-limit": "^8.3.2",
    "p-queue": "^9.1.1",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "ws": "8.18.0",
    "yargs": "17.7.2",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "pm2": "5.4.3",
    "ts-node": "10.9.2",
    "tsup": "8.3.5",
    "typescript": "5.6.3"
  },
  "trustedDependencies": []
}
