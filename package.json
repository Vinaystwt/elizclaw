{
  "name": "@elizclaw/agent",
  "version": "1.0.0",
  "description": "Personal automation agent — set it once, runs forever.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "start": "tsc && node --loader ts-node/esm src/index.ts",
    "dev": "tsc && node --loader ts-node/esm src/index.ts",
    "test": "bun test",
    "eliza": "elizaos agent start",
    "clean": "rm -rf dist data"
  },
  "dependencies": {
    "@elizaos/adapter-postgres": "0.1.9",
    "@elizaos/adapter-sqlite": "0.1.9",
    "@elizaos/client-auto": "0.1.9",
    "@elizaos/client-direct": "0.1.9",
    "@elizaos/client-discord": "0.1.9",
    "@elizaos/client-telegram": "0.1.9",
    "@elizaos/client-twitter": "0.1.9",
    "@elizaos/core": "0.1.9",
    "@elizaos/plugin-bootstrap": "0.1.9",
    "@elizaos/plugin-image-generation": "0.1.9",
    "@elizaos/plugin-node": "0.1.9",
    "@elizaos/plugin-solana": "0.1.9",
    "@elizaos/plugin-starknet": "0.1.9",
    "@tavily/core": "0.0.2",
    "amqplib": "0.10.5",
    "better-sqlite3": "11.5.0",
    "express-rate-limit": "^8.3.2",
    "fs": "0.0.1-security",
    "net": "1.0.2",
    "p-queue": "^9.1.1",
    "path": "0.12.7",
    "pino": "^10.3.1",
    "readline": "1.3.0",
    "url": "0.11.4",
    "ws": "8.18.0",
