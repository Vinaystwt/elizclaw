# ElizClaw Environment Configuration
# Copy this file to .env and fill in the values

# === AI Model (REQUIRED) ===
# Qwen3.5-27B-AWQ-4bit hosted endpoint from Nosana
# Register at nosana.com/builders-credits to get your endpoint URL and API key
OPENAI_API_KEY=your_nosana_api_key_here
OPENAI_API_URL=https://your-nosana-endpoint.nosana.io/v1

# === Server ===
SERVER_PORT=3000

# === Model Provider ===
# Using OpenAI-compatible API for the Qwen model
MODEL_PROVIDER=openai

# === Frontend (for Next.js) ===
# URL where the ElizaOS agent DirectClient is running
AGENT_URL=http://localhost:3000

# === Nosana (set when deploying) ===
# NOSANA_API_KEY=
# NOSANA_GPU_ID=
